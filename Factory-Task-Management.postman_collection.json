{
  "info": {
    "name": "Factory Task Management API",
    "description": "Complete API collection after QA fixes and update phase planning. Base URL: http://localhost:8000/api\n\nVariables:\n- base_url: http://localhost:8000/api\n- admin_token: (set after login as admin)\n- employee_token: (set after login as employee)\n- task_id, assignment_id, employee_id: set as needed\n- employee_ids, task_ids: comma-separated examples for bulk delete bodies",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "employee_token", "value": "", "type": "string" },
    { "key": "task_id", "value": "1", "type": "string" },
    { "key": "assignment_id", "value": "1", "type": "string" },
    { "key": "employee_id", "value": "2", "type": "string" },
    { "key": "employee_ids", "value": "2,3,4", "type": "string" },
    { "key": "task_ids", "value": "10,11,12", "type": "string" }
  ],
  "item": [
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('admin_token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@factory.com\",\n    \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "description": "Rate-limited: 10 attempts per minute. Returns 429 after limit."
          }
        },
        {
          "name": "Login (Employee)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('employee_token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"employee@factory.com\",\n    \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login - Rate Limit Test (429)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"wrong@test.com\",\n    \"password\": \"wrongpassword\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "description": "Run 11+ times quickly. 11th request returns 429 JSON with Retry-After header."
          }
        },
        {
          "name": "Get Authenticated User (me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Register Device Token (FCM)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"token\": \"fcm_device_token_from_flutter_app\",\n    \"device_info\": \"Samsung Galaxy S23 / Android 14\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/device-token", "host": ["{{base_url}}"], "path": ["auth", "device-token"] },
            "description": "Field: 'token' (not device_token). Uses updateOrCreate - safe to call on every app open."
          }
        },
        {
          "name": "Remove Device Token",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"token\": \"fcm_device_token_from_flutter_app\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/device-token", "host": ["{{base_url}}"], "path": ["auth", "device-token"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "02 - Admin: Employees",
      "item": [
        {
          "name": "List Employees",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/admin/employees", "host": ["{{base_url}}"], "path": ["admin", "employees"] },
            "description": "Default employee list. Planned response should be paginated and exclude soft-deleted users."
          }
        },
        {
          "name": "Search Employees",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/employees?q=ahmad&is_active=1&per_page=25",
              "host": ["{{base_url}}"],
              "path": ["admin", "employees"],
              "query": [
                { "key": "q", "value": "ahmad", "description": "Searches name, email, and phone." },
                { "key": "is_active", "value": "1", "description": "Use 1 or 0." },
                { "key": "per_page", "value": "25", "description": "Default 15, max 100." }
              ]
            }
          }
        },
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Ahmed Mohamed\",\n    \"email\": \"ahmed@factory.com\",\n    \"password\": \"secret123\",\n    \"phone\": \"+966501234567\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/admin/employees", "host": ["{{base_url}}"], "path": ["admin", "employees"] },
            "description": "Returns plain_password in response for handoff to employee. Password min 6 chars."
          }
        },
        {
          "name": "Show Employee",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/admin/employees/{{employee_id}}", "host": ["{{base_url}}"], "path": ["admin", "employees", "{{employee_id}}"] }
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Ahmed Mohamed Updated\",\n    \"email\": \"ahmed.updated@factory.com\",\n    \"phone\": \"+966509999999\",\n    \"password\": null,\n    \"is_active\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/admin/employees/{{employee_id}}", "host": ["{{base_url}}"], "path": ["admin", "employees", "{{employee_id}}"] },
            "description": "Role is not editable here. Empty/null password should not update password. Setting is_active=false revokes tokens."
          }
        },
        {
          "name": "Toggle Active Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/admin/employees/{{employee_id}}/toggle-active", "host": ["{{base_url}}"], "path": ["admin", "employees", "{{employee_id}}", "toggle-active"] },
            "description": "Deactivating revokes all Sanctum tokens for that employee immediately."
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/admin/employees/{{employee_id}}", "host": ["{{base_url}}"], "path": ["admin", "employees", "{{employee_id}}"] },
            "description": "Admin only. Should not delete admins or current authenticated admin. Preferred behavior: soft-delete employee and revoke tokens."
          }
        },
        {
          "name": "Bulk Delete Employees",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"employee_ids\": [2, 3, 4]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/admin/employees/bulk-delete", "host": ["{{base_url}}"], "path": ["admin", "employees", "bulk-delete"] },
            "description": "Expected success data: deleted_count. Must reject admin IDs and current authenticated admin."
          }
        },
        {
          "name": "Delete All Employees Except Admins",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/admin/employees", "host": ["{{base_url}}"], "path": ["admin", "employees"] },
            "description": "Admin only. Deletes/soft-deletes all users with role=employee. Must preserve admins and task history."
          }
        }
      ]
    },
    {
      "name": "03 - Admin: Tasks",
      "item": [
        {
          "name": "List Tasks (Admin - all tasks)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/tasks", "host": ["{{base_url}}"], "path": ["tasks"] },
            "description": "Existing route. Admin receives all visible tasks. Planned resources should include assigned_by."
          }
        },
        {
          "name": "Search Tasks (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/tasks?q=machine&status=active&employee_id={{employee_id}}&date_from=2026-05-01&date_to=2026-05-05&per_page=25",
              "host": ["{{base_url}}"],
              "path": ["admin", "tasks"],
              "query": [
                { "key": "q", "value": "machine", "description": "Searches task title, description, and assigned employee name/email when practical." },
                { "key": "status", "value": "active", "description": "pending, active, completed, cancelled." },
                { "key": "employee_id", "value": "{{employee_id}}" },
                { "key": "task_date", "value": "", "disabled": true },
                { "key": "date_from", "value": "2026-05-01" },
                { "key": "date_to", "value": "2026-05-05" },
                { "key": "per_page", "value": "25", "description": "Default 15, max 100." }
              ]
            },
            "description": "New admin search endpoint. Use eager loading to avoid N+1 and return paginated results."
          }
        },
        {
          "name": "Create Task (multi-employee)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Boiler Maintenance\",\n    \"description\": \"Full inspection and oil change for boiler unit 3\",\n    \"task_date\": \"2026-05-10\",\n    \"start_at\": \"2026-05-10 08:00:00\",\n    \"end_at\": \"2026-05-10 12:00:00\",\n    \"employee_ids\": [2, 3],\n    \"assignment_notes\": {\n        \"2\": \"Inspect motor bearings\",\n        \"3\": \"Replace oil filters\"\n    }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/tasks", "host": ["{{base_url}}"], "path": ["tasks"] },
            "description": "employee_ids must be active employees only. Returns 409 if any employee already has pending/active assignment. FCM task_assigned sent via queue."
          }
        },
        {
          "name": "Create Task - Conflict Test (409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Second Task Same Employee\",\n    \"task_date\": \"2026-05-11\",\n    \"start_at\": \"2026-05-11 09:00:00\",\n    \"employee_ids\": [2]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/tasks", "host": ["{{base_url}}"], "path": ["tasks"] },
            "description": "Returns 409 if employee 2 already has a pending/active assignment."
          }
        },
        {
          "name": "Show Task",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/tasks/{{task_id}}", "host": ["{{base_url}}"], "path": ["tasks", "{{task_id}}"] }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Boiler Maintenance (Updated)\",\n    \"task_date\": \"2026-05-10\",\n    \"start_at\": \"2026-05-10 09:00:00\",\n    \"end_at\": \"2026-05-10 14:00:00\",\n    \"assignment_notes\": {\n        \"2\": \"Check pressure gauges too\"\n    }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/tasks/{{task_id}}", "host": ["{{base_url}}"], "path": ["tasks", "{{task_id}}"] },
            "description": "start_at must be >= now. Cannot update completed or cancelled tasks (returns 409). FCM task_updated sent via queue."
          }
        },
        {
          "name": "Activate Task",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/tasks/{{task_id}}/activate", "host": ["{{base_url}}"], "path": ["tasks", "{{task_id}}", "activate"] },
            "description": "Only pending tasks can be activated. Sets assignments to active, sets next_reply_due_at = now+1h. FCM task_activated sent."
          }
        },
        {
          "name": "Cancel Task",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"cancel_reason\": \"Parts not available until next week\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/tasks/{{task_id}}/cancel", "host": ["{{base_url}}"], "path": ["tasks", "{{task_id}}", "cancel"] },
            "description": "Cancels all pending/active assignments. FCM task_cancelled sent. Returns 409 if already cancelled/completed."
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/admin/tasks/{{task_id}}", "host": ["{{base_url}}"], "path": ["admin", "tasks", "{{task_id}}"] },
            "description": "Admin only. Preferred behavior: cancel active/pending task then soft-delete to preserve assignments/replies history."
          }
        },
        {
          "name": "Bulk Delete Tasks",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"task_ids\": [10, 11, 12]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/admin/tasks/bulk-delete", "host": ["{{base_url}}"], "path": ["admin", "tasks", "bulk-delete"] },
            "description": "Expected success data: deleted_count. Active/pending tasks should be cancelled before soft-delete."
          }
        }
      ]
    },
    {
      "name": "04 - Employee: Tasks & Assignments",
      "item": [
        {
          "name": "List My Tasks (Employee)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "url": { "raw": "{{base_url}}/tasks", "host": ["{{base_url}}"], "path": ["tasks"] },
            "description": "Returns only tasks assigned to the authenticated employee."
          }
        },
        {
          "name": "Show Own Task (Employee)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "url": { "raw": "{{base_url}}/tasks/{{task_id}}", "host": ["{{base_url}}"], "path": ["tasks", "{{task_id}}"] },
            "description": "Returns 200 if employee is assigned. Returns 404 (not 403) if not assigned - prevents ID enumeration."
          }
        },
        {
          "name": "Show Other Employee Task - 404 Security Test",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "url": { "raw": "{{base_url}}/tasks/999", "host": ["{{base_url}}"], "path": ["tasks", "999"] },
            "description": "Expected: 404 Not Found. An employee cannot see tasks not assigned to them. 404 prevents task ID enumeration."
          }
        },
        {
          "name": "My Current Assignment",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "url": { "raw": "{{base_url}}/assignments/my-current", "host": ["{{base_url}}"], "path": ["assignments", "my-current"] },
            "description": "Returns the employee's current pending or active assignment, or null. Planned response includes assigned_by."
          }
        },
        {
          "name": "Accept Assignment",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "url": { "raw": "{{base_url}}/assignments/{{assignment_id}}/accept", "host": ["{{base_url}}"], "path": ["assignments", "{{assignment_id}}", "accept"] },
            "description": "Employee can only accept their own pending assignment. If accepted before task start, assignment remains pending. If parent task is already active, assignment becomes active and next_reply_due_at is set."
          }
        },
        {
          "name": "Reject Assignment",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"rejection_reason\": \"I am not available at this time.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/assignments/{{assignment_id}}/reject", "host": ["{{base_url}}"], "path": ["assignments", "{{assignment_id}}", "reject"] },
            "description": "Employee can only reject their own pending/active eligible assignment. rejection_reason is required. Rejected assignments should not activate, block task completion, or count as busy."
          }
        },
        {
          "name": "Reject Assignment - Missing Reason (422)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"rejection_reason\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/assignments/{{assignment_id}}/reject", "host": ["{{base_url}}"], "path": ["assignments", "{{assignment_id}}", "reject"] },
            "description": "Expected: 422 validation error because rejection_reason is required."
          }
        },
        {
          "name": "Complete Assignment",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "url": { "raw": "{{base_url}}/assignments/{{assignment_id}}/complete", "host": ["{{base_url}}"], "path": ["assignments", "{{assignment_id}}", "complete"] },
            "description": "Only the assigned employee can complete their own assignment. Returns 403 if wrong employee. When all assignments on parent task complete (or cancelled), task auto-completes."
          }
        }
      ]
    },
    {
      "name": "05 - Task Replies",
      "item": [
        {
          "name": "List Replies for Assignment",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/assignments/{{assignment_id}}/replies", "host": ["{{base_url}}"], "path": ["assignments", "{{assignment_id}}", "replies"] },
            "description": "Admin can view all replies. Employee can only view replies for their own assignment."
          }
        },
        {
          "name": "Submit Hourly Reply (Employee)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"content\": \"Completed pressure check. All valves are normal. Moving to oil filter replacement.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/assignments/{{assignment_id}}/replies", "host": ["{{base_url}}"], "path": ["assignments", "{{assignment_id}}", "replies"] },
            "description": "Content: min 5, max 2000 chars. Updates last_reply_at and next_reply_due_at (+1h). Returns 409 if assignment not active. Returns 403 if wrong employee (not 409)."
          }
        },
        {
          "name": "Reply to Wrong Assignment - 403 Security Test",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"content\": \"Trying to reply to someone else assignment\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/assignments/999/replies", "host": ["{{base_url}}"], "path": ["assignments", "999", "replies"] },
            "description": "Expected: 403 Forbidden (not 409). Policy blocks before service layer."
          }
        }
      ]
    },
    {
      "name": "06 - Location",
      "item": [
        {
          "name": "Request Employee Locations (Admin - all active)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/location/request", "host": ["{{base_url}}"], "path": ["location", "request"] },
            "description": "Omit employee_ids to target ALL active employees. Returns location_request_id and expires_at (10 min window). FCM location_requested sent via queue."
          }
        },
        {
          "name": "Request Employee Locations (Admin - specific employees)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"employee_ids\": [2, 3]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/location/request", "host": ["{{base_url}}"], "path": ["location", "request"] },
            "description": "employee_ids must be active employees only. Admin IDs or inactive users return 422."
          }
        },
        {
          "name": "Request Location - Admin ID Test (422)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"employee_ids\": [1]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/location/request", "host": ["{{base_url}}"], "path": ["location", "request"] },
            "description": "Expected: 422 - ID 1 is the admin. Only active employee IDs are accepted."
          }
        },
        {
          "name": "Submit Location (Employee)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"latitude\": 24.7136,\n    \"longitude\": 46.6753,\n    \"accuracy\": 12.5\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/location/submit", "host": ["{{base_url}}"], "path": ["location", "submit"] },
            "description": "latitude: -90 to 90, longitude: -180 to 180. Stores in employee_locations (history) and live_employee_locations (current). Links to active location_request if exists."
          }
        },
        {
          "name": "Get All Live Locations (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/location/live", "host": ["{{base_url}}"], "path": ["location", "live"] },
            "description": "Returns latest known location for all employees who have submitted at least once."
          }
        },
        {
          "name": "Get Live Location for Employee (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/location/live/{{employee_id}}", "host": ["{{base_url}}"], "path": ["location", "live", "{{employee_id}}"] },
            "description": "Returns 404 if employee has never submitted location."
          }
        }
      ]
    },
    {
      "name": "07 - Security Tests",
      "item": [
        {
          "name": "Access Admin Route as Employee (403)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "url": { "raw": "{{base_url}}/admin/employees", "host": ["{{base_url}}"], "path": ["admin", "employees"] },
            "description": "Expected: 403 Forbidden. role:admin middleware blocks employee tokens."
          }
        },
        {
          "name": "Create Task as Employee (403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Unauthorized Task\",\n    \"task_date\": \"2026-05-10\",\n    \"start_at\": \"2026-05-10 08:00:00\",\n    \"employee_ids\": [2]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/tasks", "host": ["{{base_url}}"], "path": ["tasks"] },
            "description": "Expected: 403 Forbidden."
          }
        },
        {
          "name": "Access Without Token (401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/tasks", "host": ["{{base_url}}"], "path": ["tasks"] },
            "description": "Expected: 401 Unauthenticated JSON response."
          }
        },
        {
          "name": "Deactivated Employee Login (403)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"deactivated@factory.com\",\n    \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "description": "Expected: 403 - account deactivated."
          }
        }
      ]
    }
  ]
}
